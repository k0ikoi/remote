# 3. 所有 .cn 后缀的域名无条件直连
DOMAIN-SUFFIX,cn,China
# 4. 中国大陆常见域名直连（引用纯域名规则库，不包含任何 GeoIP 和 IP-CIDR）
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Shadowrocket/China/China_Domain.list,China
GEOIP,CN,China,no-resolve


# 1. 局域网 IP 直连 (加上 no-resolve 防止针对局域网 IP 的域名进行本地反查)
IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
IP-CIDR,127.0.0.0/8,DIRECT,no-resolve
IP-CIDR6,::1/128,DIRECT,no-resolve
IP-CIDR6,FC00::/7,DIRECT,no-resolve
IP-CIDR6,FE80::/10,DIRECT,no-resolve

# 5. 兜底规则：以上没有匹配到的，全部走代理（不触发本地 DNS 解析）
FINAL,PROXY

[Host]
localhost = 127.0.0.1

[URL Rewrite]
# 将 google.cn 的 http 请求 302 跳转到 https://www.google.com
^http://(www\.)?g\.cn($|/.*) https://www.google.com$2 302
^http://(www\.)?google\.cn($|/.*) https://www.google.com$2 302
